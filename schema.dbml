// Content AI — мульти-тенантная схема (Autonomous Content Channel OS)
// Все таблицы общие, изоляция арендаторов логическая — по tenant_id.
// Сгенерировано из моделей SQLModel в database.py.

Table tenant_profiles {
  id                  int          [pk, increment]
  tenant_id          varchar      [unique, not null, note: 'Стабильный ID арендатора (не меняется)']
  chat_id            varchar      [unique, not null, note: '@username или -100... в Telegram']
  channel_name       varchar      [default: '']
  tone               varchar      [default: 'neutral']
  language           varchar      [default: 'uz']
  writing_style      varchar      [default: '']
  audience           varchar      [default: '']
  post_template      varchar      [null]
  image_style        varchar      [null]
  topics             varchar      [default: '', note: 'Темы через запятую — источник авто-генерации']
  subscription_tier  varchar      [default: 'starter', note: 'starter — только каналы где бот админ; pro — ещё и публичные по @username']
  creativity_level   float        [default: 0.5, note: '0.0–1.0 → temperature LLM']
  factual_strictness float        [default: 0.7, note: '0.0–1.0']
  active             boolean      [default: true]
  created_at         timestamp
  updated_at         timestamp

  indexes {
    tenant_id
    chat_id
  }
}

Table tenant_rules {
  id          int        [pk, increment]
  tenant_id  varchar    [not null]
  rule_type  varchar    [not null, note: 'forbidden_topic | required_hashtag | formatting | length_limit | stylistic']
  rule_value varchar    [not null]
  created_at timestamp

  indexes {
    tenant_id
  }
}

Table posts_history {
  id          int        [pk, increment]
  tenant_id  varchar    [not null]
  topic      varchar    [null]
  content    text       [not null]
  image_path varchar    [null]
  posted     boolean    [default: false]
  message_id int        [null, note: 'message_id в Telegram — нужен для сбора метрик']
  created_at timestamp

  indexes {
    tenant_id
    message_id
  }
}

Table post_metrics {
  id          int        [pk, increment]
  tenant_id  varchar    [not null]
  post_id    int        [not null, note: 'posts_history.id']
  message_id int        [not null, note: 'message_id в Telegram']
  views      int        [default: 0]
  forwards   int        [default: 0]
  reactions  int        [default: 0]
  captured_at timestamp  [note: 'Снимок метрик на момент времени (история роста охвата)']

  indexes {
    tenant_id
    post_id
  }
}

// --- Логические связи (FK на уровне приложения, по tenant_id/post_id) ---
Ref: tenant_rules.tenant_id   > tenant_profiles.tenant_id
Ref: posts_history.tenant_id  > tenant_profiles.tenant_id
Ref: post_metrics.tenant_id   > tenant_profiles.tenant_id
Ref: post_metrics.post_id     > posts_history.id
