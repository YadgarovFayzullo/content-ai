# GROQ_MODEL=llama-3.3-70b-versatile

# --- Repost-режим (копирование/переписывание чужих новостей) ---
# Модель ТОЛЬКО для переписывания репоста (отбор и topic-режим — на GROQ_MODEL).
# Покрупнее = надёжнее перевод/язык. По умолчанию = GROQ_MODEL.
# REPOST_MODEL=llama-3.3-70b-versatile
# Температура переписывания (ниже = ближе к фактам источника, меньше домыслов).
# REPOST_TEMPERATURE=0.3
# Картинка: true (по умолч.) — генерим свою; false — берём оригинал поста.
# REPOST_GENERATE_IMAGE=true
# Сколько свежих постов тянуть с каждого источника / макс. кандидатов в LLM-отбор.
# REPOST_FETCH_LIMIT=30
# REPOST_MAX_CANDIDATES=60

# --- Telethon (чтение истории каналов через MTProto) ---
# api_id / api_hash берутся на https://my.telegram.org
TELEGRAM_API_ID=37369247

TELEGRAM_API_HASH=0ebabd886bfb663627b91f409f3783eb

# StringSession из `python -m scripts.telethon_login`
