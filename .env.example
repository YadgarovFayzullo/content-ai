# GROQ_MODEL=llama-3.3-70b-versatile

# --- Repost-режим (копирование/переписывание чужих новостей) ---
# Модель ТОЛЬКО для переписывания репоста (отбор и topic-режим — на GROQ_MODEL).
# Покрупнее = надёжнее перевод/язык. По умолчанию = GROQ_MODEL.
# REPOST_MODEL=llama-3.3-70b-versatile
# Температура переписывания (ниже = ближе к фактам источника, меньше домыслов).
# REPOST_TEMPERATURE=0.3
# Картинка репоста — REPOST_IMAGE_MODE:
#   card     (по умолч.) — чистое тематическое фото из интернета (Pexels) по смыслу
#                          новости + заголовок на градиенте (нет фото → AI-иллюстрация);
#   photo    — оригинальное фото поста-источника как есть;
#   generate — всегда AI-иллюстрация.
# REPOST_IMAGE_MODE=card
# Ключ Pexels для режима card (бесплатно: https://www.pexels.com/api/):
# PEXELS_API_KEY=
# Сколько верхних результатов Pexels рассматривать (из них берётся случайный):
# PEXELS_POOL=15
# (устар.) учитывается, только если REPOST_IMAGE_MODE не задан: true→generate, false→photo
# REPOST_GENERATE_IMAGE=true
# Шрифт заголовка карточки (по умолч. bundled assets/fonts/Roboto-Bold.ttf):
# NEWS_CARD_FONT=/path/to/Bold.ttf
# Сколько свежих постов тянуть с каждого источника / макс. кандидатов в LLM-отбор.
# REPOST_FETCH_LIMIT=30
# REPOST_MAX_CANDIDATES=60
# --- V2: семантическая кластеризация + дедуп (нужен RAG /embed) ---
# Порог кластеризации (cosine): выше = дробнее группы (меньше риск склейки разных
# новостей), ниже = крупнее. Кластер из 1 поста = обычный rewrite.
# Калибровка: одно событие ≈0.85, разные ≈0.74–0.78. Дефолт консервативный.
# REPOST_CLUSTER_THRESHOLD=0.86
# Порог семантического дедупа (cosine): ниже = агрессивнее давит повторы (дубль
# хуже пропуска). За сколько дней смотреть прошлые истории.
# REPOST_DEDUP_THRESHOLD=0.83
# REPOST_DEDUP_DAYS=14

# --- Telethon (чтение истории каналов через MTProto) ---
# api_id / api_hash берутся на https://my.telegram.org
TELEGRAM_API_ID=37369247

TELEGRAM_API_HASH=0ebabd886bfb663627b91f409f3783eb

# StringSession из `python -m scripts.telethon_login`
TELETHON_SESSION=
# Сколько последних постов скрейпить при онбординге
SCRAPE_HISTORY_LIMIT=200

# --- RAG-сервис (~/Desktop/RAG) ---
RAG_URL=http://localhost:8000

# Database Configuration (Docker Postgres)
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=content_ai
# DATABASE_URL is constructed automatically in docker-compose,
# but you can override it if needed:
# DATABASE_URL=postgresql://postgres:pass@db:5432/content_ai

PEXELS_API_KEY=

# ============================================================================
# Frontend / public edge (restrict mode)
# ============================================================================
# Origin of the admin panel (content-pilot). Added to admin-api CORS allow-list
# so the deployed frontend can call the API cross-origin. Use the PUBLIC scheme
# + host of where the frontend is served (no trailing slash), e.g.:
#   FRONTEND_URL=https://app.example.com
FRONTEND_URL=

# Все сервисы (db / bot / admin-api / rag / nginx) живут в общей bridge-сети
# content_ai_net и ходят друг к другу по именам — IP/подсеть фиксировать не нужно.
# Сеть создаётся один раз перед первым запуском:  docker network create content_ai_net